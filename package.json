{
  "name": "@local/acp-agent-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "acp-agent-gateway": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "probe:agent": "node scripts/probe-agent-acp.mjs",
    "probe:opencode": "node scripts/probe-opencode-acp.mjs",
    "test": "vitest run",
    "smoke:agent": "node scripts/smoke-agent.mjs",
    "smoke:opencode": "node scripts/smoke-opencode.mjs",
    "smoke:opencode:stateful": "node scripts/smoke-opencode-stateful.mjs",
    "smoke:recovery:opencode": "SMOKE_AGENT=opencode node scripts/smoke-recovery-opencode.mjs",
    "smoke:recovery:claude": "SMOKE_AGENT=claude node scripts/smoke-recovery-claude.mjs",
    "smoke:recovery:codex": "SMOKE_AGENT=codex node scripts/smoke-recovery-codex.mjs",
    "check": "npm run lint && npm run format:check && npm run build && npm run test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.22.1",
    "zod": "4.4.3"
  },
  "bundledDependencies": [
    "@agentclientprotocol/sdk",
    "zod"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
